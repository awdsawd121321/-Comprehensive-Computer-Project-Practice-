{
  "name": "yicompanion-elderly-care-assistant",
  "private": true,
  "version": "0.0.0",
  "description": "YiCompanion (颐伴) - elderly virtual digital human companion assistant",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tts": "conda run -n emobit python scripts/edge_tts_server.py",
    "dev:all": "npm-run-all -p dev dev:tts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:functional": "vitest run -c vitest.functional.config.ts --passWithNoTests",
    "test:functional:live": "VITEST_REAL_SERVICES=1 vitest run -c vitest.functional.config.ts tests/real --passWithNoTests",
    "test:system": "vitest run -c vitest.system.config.ts --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "openclaw:bridge": "node openclaw/bridge/server.mjs",
    "data-server:start": "node backend/data-server/server.mjs",
    "openclaw:cron:bootstrap": "node openclaw/scripts/bootstrap-cron.mjs",
    "face-driving:mock": "python -m face_driving.inference.server --mock --port 10097",
    "face-driving:serve": "python -m face_driving.inference.server --checkpoint face_driving/checkpoints/best.pt --port 10097",
    "face-driving:preprocess": "python -m face_driving.preprocess.video_pipeline",
    "face-driving:train": "python -m face_driving.training.train --config face_driving/configs/default.yaml",
    "face-driving:eval": "python -m face_driving.evaluation.evaluate",
    "asr:evaluate": "node scripts/evaluate-asr-model.mjs",
    "asr:evaluate:with-errors": "node scripts/evaluate-asr-model.mjs scripts/asr-test-data-with-errors.json",
    "funasr:test": "node scripts/test-funasr-performance.mjs"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@pixiv/three-vrm": "^3.5.1",
    "dotenv": "^17.2.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "three": "0.160.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "msw": "^2.11.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "whatwg-fetch": "^3.6.20"
  }
}
